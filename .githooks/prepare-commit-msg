#!/bin/sh

set -eu

message_file="$1"
message_source="${2:-}"

case "$message_source" in
    message|merge|squash|commit)
        exit 0
        ;;
esac

repo_root="$(git rev-parse --show-toplevel)"

if grep -v '^[[:space:]]*#' "$message_file" | grep -q '[^[:space:]]'; then
    exit 0
fi

generated_message="$(php "$repo_root/scripts/generate_commit_message.php")"

if [ -z "$generated_message" ]; then
    exit 0
fi

printf '%s\n' "$generated_message" > "$message_file"
