APP_NAME=Tenanto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://tenanto.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

PENNANT_STORE=database

TENANTO_EXTRA_CHARGE_MANAGER_APPROVAL_THRESHOLD=100.00

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GITHUB_TOKEN=

TRACE_REPLAY_ENABLED=true
TRACE_REPLAY_TRACE_BAR_ENABLED=false
TRACE_REPLAY_SAMPLE_RATE=0.1
TRACE_REPLAY_MAX_PAYLOAD_SIZE=16384
TRACE_REPLAY_BATCH_PERSISTENCE=true
TRACE_REPLAY_QUEUE_ENABLED=false
TRACE_REPLAY_QUEUE_CONNECTION="${QUEUE_CONNECTION}"
TRACE_REPLAY_QUEUE_NAME=default
TRACE_REPLAY_TRACK_DB=false
TRACE_REPLAY_TRACK_DB_BINDINGS=false
TRACE_REPLAY_SKIP_PATHS=livewire/*
TRACE_REPLAY_SKIP_ROUTES=filament.admin.pages.dashboard
TRACE_REPLAY_ROUTE_PREFIX=trace-replay
TRACE_REPLAY_ALLOWED_IPS=
TRACE_REPLAY_RETENTION_DAYS=30
TRACE_REPLAY_REPLAY_URL="${APP_URL}"
TRACE_REPLAY_REPLAY_TIMEOUT=30
TRACE_REPLAY_REPLAY_MUTATING=false
TRACE_REPLAY_REPLAY_ALLOWED_HOSTS=
TRACE_REPLAY_API_TOKEN=
TRACE_REPLAY_API_ROUTE_PREFIX=api/trace-replay
TRACE_REPLAY_API_MAX_STEPS=500
TRACE_REPLAY_NOTIFY_ON_FAILURE=false
TRACE_REPLAY_NOTIFY_CHANNELS=mail
TRACE_REPLAY_NOTIFY_EMAIL=
TRACE_REPLAY_SLACK_WEBHOOK=
TRACE_REPLAY_AI_DRIVER=openai
TRACE_REPLAY_AI_KEY=
TRACE_REPLAY_AI_MODEL=gpt-4o
TRACE_REPLAY_AI_BASE_URL=
TRACE_REPLAY_AUTO_TRACE_JOBS=false
TRACE_REPLAY_AUTO_TRACE_COMMANDS=false
TRACE_REPLAY_AUTO_TRACE_LIVEWIRE=false
TRACE_REPLAY_CAPTURE_JOB_PAYLOAD=false

VITE_APP_NAME="${APP_NAME}"
